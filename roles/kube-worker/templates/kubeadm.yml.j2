apiVersion: kubeadm.k8s.io/v1beta4
kind: JoinConfiguration
patches:
  directory: "{{ kubelet_config_path }}/patches/"
{% if not node_kubelet_conf.stat.exists %}
discovery:
  bootstrapToken:
    apiServerEndpoint: {{ kubernetes_control_plane_address }}
    token: {{ kubernetes_bootstrap_token }}
    caCertHashes:
      - {{ kubernetes_ca_hash }}
{% endif %}
nodeRegistration:
  name: {{ kubernetes_hostname }}
  kubeletExtraArgs:
    - name: cloud-provider
      value: {{ kubernetes_cloud_provider }}
    - name: node-labels
      value: "node.kubernetes.io/role={{ kubernetes_role}}"
{% if kubernetes_taints | length > 0 %}
  taints:
{{ kubernetes_taints | to_nice_yaml | indent(4, true) }}
{%- endif -%}
