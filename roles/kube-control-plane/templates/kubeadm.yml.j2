apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
nodeRegistration:
  name: {{ kubernetes_hostname }}
  kubeletExtraArgs:
    - name: cloud-provider
      value: {{ kubernetes_cloud_provider }}
{% if kubernetes_taints is defined %}
  taints:
{{ kubernetes_taints | to_yaml | indent(4, true) }}
{%- endif -%}

localAPIEndpoint:
  advertiseAddress: {{ kubernetes_apiserver_advertise_address }}
  bindPort: 6443
patches:
  directory: {{ kubeadm_patches_path }}
skipPhases: {{ kubeadm_skip_phases | to_yaml | indent(2) }}
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
etcd:
  external:
    endpoints:
{{ etcd_endpoints | to_nice_yaml | indent(4, true) }}
    caFile: {{ etcd_ca_file }}
    certFile: {{ etcd_cert_file }}
    keyFile: {{ etcd_key_file }}
clusterName: {{ kubernetes_cluster_name }}
kubernetesVersion: {{ kubernetes_version }}
imageRepository: "{{ kubernetes_image_registry }}"
controlPlaneEndpoint: {{ kubernetes_control_plane_address }}
dns:
{% if coredns_image_prefix != "" %}
  imageRepository: {{ kubernetes_image_registry }}{{ coredns_image_prefix }}
{% endif %}
apiServer:
{% if kubernetes_apiserver_certSANs | length %}
  certSANs:
{{ kubernetes_apiserver_certSANs | to_nice_yaml | indent(2, true) -}}
{% endif %}
  extraArgs:
{% if tls_cipher_suites is defined %}
    - name: tls-cipher-suites
      value: {{ tls_cipher_suites | join(',') }}
{% endif %}
    - name: enable-admission-plugins
      value: "NamespaceLifecycle,LimitRanger,PodNodeSelector,ServiceAccount,DefaultStorageClass,DefaultTolerationSeconds,MutatingAdmissionWebhook,ValidatingAdmissionWebhook,ResourceQuota,EventRateLimit,NodeRestriction,DenyServiceExternalIPs"
    - name: admission-control-config-file
      value: "{{ eventratelimit_config_file | default('/etc/kubernetes/admission-config.yaml') }}"
{% if kubernetes_cloud_provider != "" and kubernetes_version is version('1.33.0', '<') %}
    - name: cloud-provider
      value: {{ kubernetes_cloud_provider }}
{% endif %}
    - name: kubelet-certificate-authority
      value: {{ kubelet_certificate_authority_file | default ('/etc/kubernetes/pki/ca.crt') }}
    - name: request-timeout
      value: "60s"
{% if kubernetes_cloud_config != "" and kubernetes_version is version('1.33.0', '<') %}
    - name: cloud-config
      value: {{ kubernetes_cloud_config }}
{% endif %}
    - name: audit-log-path
      value: "{{ audit_log_dir }}/kube-apiserver-audit.log"
    - name: audit-policy-file
      value: {{ audit_policy_config_path }}
    - name: audit-log-maxage
      value: "{{ audit_policy_max_age }}"
    - name: audit-log-maxsize
      value: "{{ audit_policy_max_size }}"
    - name: audit-log-maxbackup
      value: "{{ audit_policy_max_backup }}"
    - name: service-account-extend-token-expiration
      value: "false"
{% if kubernetes_encryption_config != "" %}
    - name: encryption-provider-config
      value: {{ kubernetes_remote_encryption_config }}
{% endif %}
{% if oidc_issuer_url != "" %}
    - name: oidc-issuer-url
      value: {{ oidc_issuer_url }}
    - name: oidc-client-id
      value: {{ oidc_client_id }}
    - name: oidc-ca-file
      value: {{ oidc_ca_file }}
    - name: oidc-username-claim
      value: "{{ oidc_username_claim }}"
    - name: oidc-username-prefix
      value: "{{ oidc_username_prefix }}"
    - name: oidc-groups-claim
      value: "{{ oidc_groups_claim }}"
    - name: oidc-groups-prefix
      value: "{{ oidc_groups_prefix }}"
{% endif %}
{% if service_account_issuer is defined %}
    - name: service-account-issuer
      value: "{{ service_account_issuer }}"
{% endif %}
{% if api_audiences is defined %}
    - name: api-audiences
      value: "{{ api_audiences }}"
{% endif %}
    - name: profiling
      value: "false"
  extraVolumes:
  - name: audit-files
    hostPath: {{ audit_log_dir }}
    mountPath: {{ audit_log_dir }}
    readOnly: false
    pathType: Directory
  - name: audit-policy
    hostPath: {{ audit_policy_config_path }}
    mountPath: {{ audit_policy_config_path }}
    readOnly: true
    pathType: File
  - name: admission
    hostPath: {{ eventratelimit_config_file | default('/etc/kubernetes/admission-config.yaml') }}
    mountPath: {{ eventratelimit_config_file | default('/etc/kubernetes/admission-config.yaml') }}
    readOnly: true
    pathType: File
{% if kubernetes_encryption_config != "" %}
  - name: encryption-configuration
    hostPath: {{ kubernetes_remote_encryption_config }}
    mountPath: {{ kubernetes_remote_encryption_config }}
    readOnly: true
    pathType: File
{% endif %}
{% if kubernetes_cloud_config != "" and kubernetes_version is version('1.33.0', '<') %}
  - name: cloud
    hostPath: {{ kubernetes_cloud_config }}
    mountPath: {{ kubernetes_cloud_config }}
    readOnly: true
    pathType: File
{% endif %}
scheduler:
  extraArgs:
{% if tls_cipher_suites is defined %}
    - name: tls-cipher-suites
      value: {{ tls_cipher_suites | join(',') }}
{% endif %}
    - name: profiling
      value: "false"
controllerManager:
  extraArgs:
{% if tls_cipher_suites is defined %}
    - name: tls-cipher-suites
      value: {{ tls_cipher_suites | join(',') }}
{% endif %}
    - name: cloud-provider
      value: {{ kubernetes_cloud_provider }}
{% if kubernetes_cloud_config != "" %}
    - name: cloud-config
      value: {{ kubernetes_cloud_config }}
{% endif %}
# Disables profiling (always false by default)
    - name: profiling
      value: "false"
# Reduced default value for maximum number of terminated pods kept by the controller-manager before removal (default 12500)
{% if terminated_pod_gc_threshold is defined %}
    - name: terminated-pod-gc-threshold
      value: "{{ terminated_pod_gc_threshold }}"
{% endif %}
{% if kubernetes_cloud_config != "" %}
  extraVolumes:
  - name: cloud
    hostPath: {{ kubernetes_cloud_config }}
    mountPath: {{ kubernetes_cloud_config }}
    readOnly: true
    pathType: File
{% endif %}
networking:
  podSubnet: {{ kubernetes_pod_cidr }}
  serviceSubnet: {{ kubernetes_svc_cidr }}
  dnsDomain: "cluster.local"
---
apiVersion: kubeproxy.config.k8s.io/v1alpha1
kind: KubeProxyConfiguration
bindAddress: 0.0.0.0
clusterCIDR: "{{ kubernetes_pod_cidr }}"
metricsBindAddress: 0.0.0.0:10249
mode: nftables
---
{# This KubeletConfiguration, from the first control-plane node, will end up being saved by kubeadm in the
`kube-system/kubelet-config` configMap that all nodes will use to configure their kubelet so we just set
general options here and leave all the rest parameters at their default value.
The custom parameters for each node are set via patches.
#}
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
